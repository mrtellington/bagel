# Required — app will not start without these
ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-1-your-app-level-token
ASANA_PAT=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CALENDAR_SA_KEY_BASE64=

# Required — workspace/user-specific IDs
SLACK_CHANNEL_ID=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
ASANA_BACKLOG_SECTION_GID=
GRANOLA_SOURCE_UUID=
OWNER_SLACK_USER_ID=
OWNER_ASANA_EMAIL=

# Optional — used in system prompt and display
OWNER_NAME=
OWNER_TITLE=
ORG_NAME=

# Optional — defaults shown
TIMEZONE=America/New_York
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
